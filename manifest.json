{
  "manifest_version": 3,
  "name": "Meet Recorder",
  "version": "1.0",

  "permissions": [
    "tabCapture",
    "offscreen",
    "activeTab",
    "downloads",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
    
  },
  "options_page": "options.html"
}